{
  "name": "setup-tombi",
  "version": "1.0.1",
  "private": true,
  "description": "GitHub Action to set up Tombi",
  "main": "dist/index.js",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "ncc build src/index.ts -o dist",
    "format": "biome format --fix",
    "format-check": "biome format",
    "lint": "biome lint --fix",
    "lint-check": "biome lint",
    "test": "vitest run",
    "test:lockfile-generated": "cross-env LOCKFILE_GENERATION_TEST=1 vitest run tests/lockfile/generated/*.test.ts",
    "test:lockfile-generated:uv": "cross-env LOCKFILE_GENERATION_TEST=1 vitest run tests/lockfile/generated/uv-generated.test.ts",
    "test:lockfile-generated:poetry": "cross-env LOCKFILE_GENERATION_TEST=1 vitest run tests/lockfile/generated/poetry-generated.test.ts",
    "test:lockfile-generated:pnpm": "cross-env LOCKFILE_GENERATION_TEST=1 vitest run tests/lockfile/generated/pnpm-generated.test.ts",
    "test:lockfile-generated:npm": "cross-env LOCKFILE_GENERATION_TEST=1 vitest run tests/lockfile/generated/npm-generated.test.ts",
    "test:lockfile-generated:yarn": "cross-env LOCKFILE_GENERATION_TEST=1 vitest run tests/lockfile/generated/yarn-generated.test.ts",
    "test:lockfile-generated:bun": "cross-env LOCKFILE_GENERATION_TEST=1 vitest run tests/lockfile/generated/bun-generated.test.ts",
    "codex": "npx @openai/codex@latest",
    "claude": "npx @anthropic-ai/claude-code@latest"
  },
  "keywords": ["github", "actions", "tombi", "toml", "setup"],
  "author": "tombi-toml",
  "license": "MIT",
  "packageManager": "pnpm@10.10.0",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/tool-cache": "^2.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^20.11.24",
    "@vercel/ncc": "^0.38.1",
    "cross-env": "^7.0.3",
    "typescript": "^5.3.3",
    "vitest": "^3.1.3"
  }
}
